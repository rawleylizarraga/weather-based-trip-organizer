<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link rel="stylesheet" href="/css/loginstyles.css">
</head>
<body>

    <header>

    </header>

    <nav>
        <a href="/">
            <button> Home </button>
        </a>
    </nav>

    <main>
        <span id="loginError">
            <% if (typeof error !== 'undefined' && error) { %>
                <%= error %> <br>
            <% } %>
        </span>

        <!-- use btnRegister to hide login form and display create account form -->
        <form method="POST" action="/login" id="loginForm">

            <h2>Login</h2>

            Username:
            <input type="text" name="username" id="loginUsername" required>
            <br>
            Password:
            <input type="password" name="password" id="loginPass" required>
            <br>

            <button id="btnLogin">Login</button> <br>
            <button id="btnRegister" type="button">Create New Account</button>

        </form>

        <!-- use btnCreateAccountCancel to hide create account form and display login form -->
        <div id="registerForm" hidden>
            <form method="POST" action="/register" id="registerForm">

                <h2>Create Account</h2>

                Username:
                <input type="text" name="username" id="regUsername" required>
                <br>
                Password:
                <input type="password" name="password" id="regPass" required>
                <br>
                Confirm Password:
                <input type="password" name="passConfirm" id="regPassConf" required>
                <br>

                <button id="btnCreateAccount">Create Account</button> <br>
                <button id="btnCreateAccountCancel" type="button">Back to Login</button>

            </form>
        </div>

        <!-- <form action="/logout">
            <button id="btnLogout">Logout</button>
        </form> -->
    </main>

    <%- include("partials/footer.ejs") %>

    <script src="/js/loginScript.js"></script>
    
</body>
</html>