<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link rel="stylesheet" href="/css/loginstyles.css">
    <link rel="stylesheet" href="/css/styles.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

    <header>

    </header>


    <div class="container py-4">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                            <div class="mb-3">
                                <a href="/" class="btn btn-outline-primary btn-sm">Home</a>
                            </div>

                        <span id="loginError">
                            <% if (typeof error !== 'undefined' && error) { %>
                                <%= error %> <br>
                            <% } %>
                        </span>

        <!-- use btnRegister to hide login form and display create account form -->
        <form method="POST" action="/login" id="loginForm">

            <h2 class="text-center mb-4">Login</h2>

            Username:
            <input type="text" name="username" id="loginUsername" class="form-control" required>
            <br>
            Password:
            <input type="password" name="password" id="loginPass" class="form-control" required>
            <br>

            <div class="d-grid gap-2">
                <button id="btnLogin" class="btn btn-primary">Login</button>
                <button id="btnRegister" type="button" class="btn btn-outline-secondary">Create New Account</button>
            </div>

        </form>

        <!-- use btnCreateAccountCancel to hide create account form and display login form -->
        <div id="registerForm" hidden>
            <form method="POST" action="/register" id="registerForm">

                <h2 class="text-center mb-4">Create Account</h2>

                Username:
                <input type="text" name="username" id="regUsername" class="form-control" required>
                <br>
                Password:
                <input type="password" name="password" id="regPass" class="form-control" required>
                <br>
                Confirm Password:
                <input type="password" name="passConfirm" id="regPassConf" class="form-control" required>
                <br>

                <div class="mb-4">
                    <h5 class="mb-3">Preferred profile picture</h5>

                    <div class="d-flex flex-wrap gap-3">
                        <% profilePictures.forEach(pic => { %>
                        <label class="text-center">
                            <input type="radio" name="profilePic" value="<%= pic %>" <%= pic === profilePictures[0] ? "checked" : "" %>>
                            <img src="/img/<%= pic %>" class="avatar rounded border">
                        </label>
                        <% }) %>
                    </div>
                </div>

                <div>
                    <h5 class="mb-3">Preferred temperature unit</h5>
                    <span>F°</span>
                    <label class="switch">
                        <input type="checkbox" name="tempUnit" value="C">
                        <span class="slider round"></span>
                    </label>
                    <span>C°</span>
                </div> <br><br>

                <div class="d-grid gap-2">
                    <button id="btnCreateAccount" class="btn btn-success">Create Account</button>
                    <button id="btnCreateAccountCancel" type="button" class="btn btn-outline-secondary">Back to Login</button>
                </div>

            </form>
        </div>

        <!-- <form action="/logout">
            <button id="btnLogout">Logout</button>
        </form> -->

                    </div>
                </div>
            </div>
        </div>
    </div>
    <%- include("partials/footer.ejs") %>

    <script src="/js/loginScript.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>